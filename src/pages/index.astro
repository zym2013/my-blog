---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.vue";
import HomePage from "../components/HomePage.vue";
import { config, type SiteConfig } from '../lib/config';
interface IndexProps {
  title?: string;
  description?: string;
  isHome?: boolean;
  homeConfig?: SiteConfig;
}
const {
  title = config.home?.typedName,
  description = "个人主页 · 编程项目与技术分享",
  isHome = true,
  homeConfig: incomingHomeConfig,
} = Astro.props as IndexProps;
const finalHomeConfig = incomingHomeConfig || config || ({} as SiteConfig);
const serializableHomeConfig = JSON.parse(JSON.stringify(finalHomeConfig));
---

<Layout title={title} description={description} isHome={isHome}>
  <ThemeToggle client:load />
  <HomePage client:load config={serializableHomeConfig} />
</Layout>